# ─────────────────────────────────────────────
#  Atlas Poller — Universal Config
#  1. Copy this file:  cp atlas.env.example atlas.env
#  2. Fill in your values below
#  3. Run:  ./start-atlas.sh   (or double-click it)
# ─────────────────────────────────────────────

# Your Railway app URL (no trailing slash)
RAILWAY_URL=https://your-app.railway.app

# Secret key that protects the /poll endpoint on Railway
# Must match the POLL_API_KEY secret set on your Railway service
POLL_API_KEY=your-poll-api-key-here

# Where your local Atlas agent is running
ATLAS_URL=http://localhost:8644

# Atlas webhook route name (leave as "zernio" unless you changed it)
ATLAS_ROUTE=zernio

# How often to check for new webhooks in milliseconds (default: 3000 = 3 seconds)
POLL_INTERVAL_MS=3000
